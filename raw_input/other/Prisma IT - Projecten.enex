      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>- Rail compiler only Java or something else?</div><div>- Eval. Ruby</div><div>- <a href="https://kubernetes.io/">https://kubernetes.io/</a></div><div><br/></div><div>- Setup regular tech meeting.</div><div><br/></div><div><br/></div><div><br/></div><div><table style="width: 100%; border-collapse: collapse; table-layout: fixed;"><tbody><tr><td style="width: 33.333333333333336%; border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Jochem</div></td><td style="width: 33.333333333333336%; border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="width: 33.333333333333336%; border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Wouter</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>P4139 - ForEyeT - Press Agent</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Tim</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>P4140 - NS - OBIS<br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Talentsoft</div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Piotr</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>P4140 - NS - OBIS<br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>David</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><br/></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>2e kamer / fx/html</div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Steven</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>fx/html</div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Astrid</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Mark<br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>P4140 - NS - OBIS<br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Ferry</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>BC</div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Humphrey</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Victor</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Marius</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>FX/HTML</div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Ralph</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Peter</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr><tr><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div>Suriya</div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td><td style="border: 1px solid rgb(219, 219, 219); padding: 10px; margin: 0px;"><div><br/></div></td></tr></tbody></table></div><div><br/></div><div><br/></div><div>Talentsoft - met Mark doornemen</div><div>SZW SSC - Jochem plannen in zijn agenda</div><div>1GB - kan naar Victor</div><div><br/></div><div>Nieuwsbrieven / Mobile API</div><div><br/></div><div><br/></div><div><br/></div></en-note>      ]]>

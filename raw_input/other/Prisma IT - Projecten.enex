      <source>desktop.mac</source>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note>
<div><b>Unify</b></div>
<div><br/></div>
<div>- 11/9 opgeleverd in productie</div>
<div><br/></div>
<div><en-todo/>Protocol van Oplevering sturen</div>
<div><br/></div>
<div><br/></div>
<div><b>AWS</b></div>
<div><b><br/></b></div>
<div>- 15/9 opgeleverdin productie</div>
<div><br/></div>
<div><en-todo/>Protocol van Oplevering sturen</div>
<div><br/></div>
<div><br/></div>
<div><b>Boomerang</b></div>
<div><b><br/></b></div>
<div>- Marcel uitgenodigd nieuw theme te zoeken op themeforrest</div>
<div><br/></div>
<div><br/></div>
<div><b>Overig</b></div>
<div><b><br/></b></div>
<div>- Ron maakt afspraak voor brainstorm sessie in September</div>
<div><br/></div>
<div><br/></div>
<div>
<hr/></div>
<div><b>STATUS AWS MIGRATIE</b></div>
<div><br/></div>
<div>
<div>Begin forwarded message:</div>
<br clear="none" />
<div style="margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;"><span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif; color:rgba(0, 0, 0, 1.0);"><b>From:</b></span> <span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif;">Jochem van Dieten &lt;<a shape="rect" href="mailto:jochem@prisma-it.com">jochem@prisma-it.com</a>><br clear="none" /></span></div>
<div style="margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;"><span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif; color:rgba(0, 0, 0, 1.0);"><b>Subject:</b></span> <span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif;"><b>FW: status migratie</b><br clear="none" /></span></div>
<div style="margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;"><span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif; color:rgba(0, 0, 0, 1.0);"><b>Date:</b></span> <span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif;">14 Sep 2015 16:38:05 CEST<br clear="none" /></span></div>
<div style="margin-top: 0px; margin-right: 0px; margin-bottom: 0px; margin-left: 0px;"><span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif; color:rgba(0, 0, 0, 1.0);"><b>To:</b></span> <span style="font-family: -webkit-system-font, Helvetica Neue, Helvetica, sans-serif;">Simon Slooten &lt;<a shape="rect" href="mailto:slooten@prisma-it.com">slooten@prisma-it.com</a>><br clear="none" /></span></div>
<br clear="none" /></div>
<div>
<div style="page: WordSection1; font-family: Times; font-style: normal; font-variant: normal; font-weight: normal; letter-spacing: normal; orphans: auto; text-align: start; text-indent: 0px; text-transform: none; white-space: normal; widows: auto; word-spacing: 0px; -webkit-text-stroke-width: 0px;">
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(31, 73, 125);">FYI</span></div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(31, 73, 125);"> </span></div>
<div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span lang="EN-US" style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US">With kind regards,</span></div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><b><span lang="EN-US" style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US"> </span></b></div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><b><span lang="EN-US" style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US">Jochem van Dieten</span></b></div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span lang="EN-US" style="font-size: 10pt; font-family: Tahoma, sans-serif; color: gray;" xml:lang="EN-US"><br clear="none" /></span><b><span lang="EN-US" style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US">PRISMA IT<br clear="none" /></span></b><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US">Hoofdweg 178</span></div>
<p style="margin: 0cm 0cm 12pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US">3067 GJ Rotterdam<br clear="none" />
The Netherlands</span></p>
<p style="margin: 0cm 0cm 12pt; font-size: 11pt; font-family: Calibri, sans-serif;"><b><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US">T</span></b><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US"> +31 10 4587148 <br clear="none" />
<b>M </b>+31 61 1994369</span></p>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);"><a shape="rect" href="http://prisma-it.com/" style="color: purple; text-decoration: underline;"><span lang="EN-US" style="color: rgb(5, 99, 193); text-decoration: none;" xml:lang="EN-US">website</span></a> </span><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: gray;" xml:lang="EN-US">|</span><span style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);"><a shape="rect" href="mailto:jochem@prisma-it.com" style="color: purple; text-decoration: underline;"><span lang="EN-US" style="color: rgb(5, 99, 193); text-decoration: none;" xml:lang="EN-US"> email</span></a> </span><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: gray;" xml:lang="EN-US">| </span><span style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);"><a shape="rect" href="https://twitter.com/Prisma_IT" style="color: purple; text-decoration: underline;"><span lang="EN-US" style="color: rgb(5, 99, 193); text-decoration: none;" xml:lang="EN-US">twitter</span></a> </span><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: gray;" xml:lang="EN-US">|</span><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);" xml:lang="EN-US"> </span><span style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(23, 54, 93);"><a shape="rect" href="https://www.facebook.com/PrismaIT.BV" style="color: purple; text-decoration: underline;"><span lang="EN-US" style="color: rgb(5, 99, 193); text-decoration: none;" xml:lang="EN-US">facebook</span></a> </span><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: gray;" xml:lang="EN-US">|</span><span lang="EN-US" style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(0, 32, 96);" xml:lang="EN-US"> </span><span style="font-size: 8pt; font-family: Tahoma, sans-serif; color: rgb(0, 32, 96);"><a shape="rect" href="https://www.linkedin.com/company/prisma-it" style="color: purple; text-decoration: underline;"><span lang="EN-US" style="color: rgb(0, 32, 96); text-decoration: none;" xml:lang="EN-US">linkedin</span></a></span></div>
</div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span style="font-size: 10pt; font-family: Tahoma, sans-serif; color: rgb(31, 73, 125);"> </span></div>
<div>
<div style="border-style: solid none none; border-top-color: rgb(225, 225, 225); border-top-width: 1pt; padding: 3pt 0cm 0cm;">
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><b><span lang="EN-US" xml:lang="EN-US">From:</span></b><span lang="EN-US" xml:lang="EN-US"> Marcel Hogervorst [<a shape="rect" href="mailto:M.Hogervorst@stokvis.eu" style="color: purple; text-decoration: underline;">mailto:M.Hogervorst@stokvis.eu</a>] <br clear="none" />
<b>Sent:</b> maandag 14 september 2015 16:35<br clear="none" />
<b>To:</b> Jochem van Dieten &lt;<a shape="rect" href="mailto:jochem@prisma-it.com" style="color: purple; text-decoration: underline;">jochem@prisma-it.com</a>><br clear="none" />
<b>Subject:</b> RE: status migratie</span></div>
</div>
</div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"> </div>
<div style="margin: 0cm 0cm 0.0001pt; font-size: 11pt; font-family: Calibri, sans-serif;"><span style="color: rgb(31, 73, 125);">Jochem, van de volgende sites heb het DNS IP nummer bij Transip gewijzigd in 52.16.34.190</span></div>
<div style="margin: 0cm 0cm 0.0001pt 36pt; font-size: 11pt; font-family: Calibri, sans-serif; text-indent: -18pt;"><span style="font-family: Symbol; color: rgb(31, 73, 125);">·<span style="font-style: normal; font-variant: normal; font-weight: normal; font-size: 7pt; font-family: 'Times New Roman';">         </span></span><span style="color: rgb(31, 73, 125);"><a shape="rect" href="http://elsto.eu/" style="color: purple; text-decoration: underline;">Elsto.eu</a></span></div>

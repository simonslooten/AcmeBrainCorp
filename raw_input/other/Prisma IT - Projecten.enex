  <note>
    <title>Projecten overzicht per 20160406</title>
    <created>20160406T142922Z</created>
    <updated>20160406T142948Z</updated>
    <note-attributes>
      <author>simon@simonslooten.com</author>
      <source>desktop.mac</source>
    </note-attributes>
    <content>

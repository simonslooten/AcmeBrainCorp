      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note><div>Voorstel voor nieuwe uurtarieven</div><div><br/></div><div>Development</div><div>     Junior                          <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>100               </div><div>     Medior                         <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>110               </div><div>     Senior                          <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>125              </div><div>Consultancy (dev)            </div><div>     Junior                          <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>125</div><div>     Medior                         <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>150</div><div>     Senior                          <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>175              </div><div>Consultancy (Analytics)</div><div>     Junior                           <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>100  </div><div>     Medior                          <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>110              </div><div>     Senior                           <span>    <span>    <span>    <span>    <span>    <span>    <span>    </span></span></span></span></span></span></span>125</div><div><br/></div><div>Project Management                              150<br/></div><div>System Management        <span>    <span>    <span>    <span>    <span>    <span> </span></span></span></span></span></span>110       </div><div><br/></div><div>Training (per dag)              <span>    <span>    <span>    <span>    <span>    <span>   </span></span></span></span></span></span>2.000,- <br/></div><div><br/></div><div>Maximale korting op deze tarieven zonder overleg: 10%</div><div><br/></div><div><br/></div><div><br/></div><div>    </div><div><br/></div></en-note>      ]]>

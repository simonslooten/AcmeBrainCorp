  <note>
    <title>Voorstel PNL Telefoon regeling 2015</title>
    <created>20150109T142340Z</created>
    <updated>20150123T143703Z</updated>
    <note-attributes>
      <author>simon@simonslooten.com</author>
      <source>desktop.mac</source>
    </note-attributes>
    <content>
      <![CDATA[<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!DOCTYPE en-note SYSTEM "http://xml.evernote.com/pub/enml2.dtd"><en-note>
<div><br/></div>
<table style="-evernote-table:true;border-collapse:collapse;margin-left:0px;table-layout:fixed;width:100%;">
<tr>
<td style="border-style:solid;border-width:1px;border-color:rgb(219,219,219);padding:10px;margin:0px;width:25.03113325031133%;">
<div>Model</div>
</td>
<td style="border-style:solid;border-width:1px;border-color:rgb(219,219,219);padding:10px;margin:0px;width:25.03113325031133%;">
<div>Memory</div>
</td>
<td style="border-style:solid;border-width:1px;border-color:rgb(219,219,219);padding:10px;margin:0px;width:24.906600249066003%;">
<div>Prijs</div>
</td>
<td style="border-style:solid;border-width:1px;border-color:rgb(219,219,219);padding:10px;margin:0px;width:24.906600249066003%;">
<div>Eigen Bijdrage (36 mnd)</div>
</td>
</tr>
<tr>
